    namespace Version {
        const int RELEASE = @PROJECT_VERSION_MAJOR@;
        const int MAJOR = @PROJECT_VERSION_MINOR@;
        const int MINOR = @PROJECT_VERSION_PATCH@;
    }
}

#endif // SOUNDKONVERTER_VERSION_H
